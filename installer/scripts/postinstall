#!/bin/bash
set -e

# ---------------------------------------------------------------------------
# Detect the logged-in user (PKG scripts run as root)
# ---------------------------------------------------------------------------
LOGGED_IN_USER=$(scutil <<< "show State:/Users/ConsoleUser" \
  | awk '/Name :/ && ! /loginwindow/ { print $3 }')

if [ -z "$LOGGED_IN_USER" ]; then
  echo "Could not determine logged-in user, skipping user setup"
  exit 0
fi

INSTALL_HOME=$(dscl . -read /Users/"$LOGGED_IN_USER" NFSHomeDirectory \
  | awk '{print $2}')

FELIX_DIR="$INSTALL_HOME/.felix"
SKILLS_DIR="$FELIX_DIR/skills"
CONFIG="$FELIX_DIR/felix.json5"

# ---------------------------------------------------------------------------
# Create directories and copy bundled skills
# ---------------------------------------------------------------------------
mkdir -p "$SKILLS_DIR"

BUNDLED_SKILLS="/usr/local/share/felix/skills"
if [ -d "$BUNDLED_SKILLS" ]; then
  cp -n "$BUNDLED_SKILLS"/*.md "$SKILLS_DIR/" 2>/dev/null || true
fi

# ---------------------------------------------------------------------------
# Remove quarantine from the app
# ---------------------------------------------------------------------------
xattr -dr com.apple.quarantine /Applications/Felix.app 2>/dev/null || true

# ---------------------------------------------------------------------------
# Provider setup — only if no config exists yet
# ---------------------------------------------------------------------------
if [ ! -f "$CONFIG" ]; then

  # Bundled-Ollama path — skip the API-key prompt entirely.
  BUNDLED_OLLAMA="/Applications/Felix.app/Contents/Resources/bin/ollama"
  if [ -x "$BUNDLED_OLLAMA" ]; then

    # Ask which local model to configure (Felix downloads it later).
    LOCAL_PICK=$(sudo -u "$LOGGED_IN_USER" osascript <<'OSASCRIPT'
set choices to {"gemma4:latest (~9.6 GB, recommended)", "qwen3.5:9b (~5 GB)"}
set picked to choose from list choices ¬
  with prompt "Pick a local model for Felix to use." ¬
  default items {"gemma4:latest (~9.6 GB, recommended)"} ¬
  without multiple selections allowed and empty selection allowed
if picked is false then return "gemma4:latest"
set choice to item 1 of picked
if choice starts with "qwen" then
  return "qwen3.5:9b"
else
  return "gemma4:latest"
end if
OSASCRIPT
    )
    LOCAL_MODEL="${LOCAL_PICK:-gemma4:latest}"

    cat > "$CONFIG" <<EOF
{
  "agents": {
    "list": [{
      "id": "default",
      "name": "Assistant",
      "workspace": "$FELIX_DIR/workspace-default",
      "model": "local/$LOCAL_MODEL",
      "sandbox": "none",
      "tools": { "allow": ["read_file","write_file","edit_file","bash","web_fetch","web_search","browser","send_message","cron"] }
    }]
  },
  "bindings": [{ "agentId": "default", "match": { "channel": "cli" } }],
  "channels": { "cli": { "enabled": true, "interactive": true } },
  "local": { "enabled": true, "keep_alive": "5m" },
  "providers": {
    "local": { "kind": "local", "base_url": "http://127.0.0.1:18790/v1" }
  }
}
EOF
    chmod 600 "$CONFIG"
    # Recursively own the whole Felix data dir, not just the config — Felix
    # creates more files at runtime (encryption key, ollama models, sessions)
    # and they all need to be writable by the installing user.
    chown -R "$LOGGED_IN_USER":staff "$FELIX_DIR"

    # Drop a helper script that starts a temporary ollama server, pulls the
    # chosen model, and stops the server. We open it in Terminal so the user
    # sees ollama's progress bar and can interrupt with Ctrl-C if needed. The
    # installer itself doesn't block on the multi-GB download.
    HELPER="/tmp/felix-pull-model-$$.sh"
    cat > "$HELPER" <<HELPER_EOF
#!/bin/bash
set -u
MODEL="$LOCAL_MODEL"
OLLAMA_BIN="/Applications/Felix.app/Contents/Resources/bin/ollama"
export OLLAMA_HOST="127.0.0.1:18790"
export OLLAMA_MODELS="\$HOME/.felix/ollama/models"
mkdir -p "\$OLLAMA_MODELS"

echo "Felix is downloading \$MODEL into \$OLLAMA_MODELS."
echo

# Reuse a running supervisor if Felix is already open; otherwise start a
# temporary ollama serve just for the pull and stop it when done.
SERVE_PID=""
if ! curl -fsS "http://\$OLLAMA_HOST/api/version" >/dev/null 2>&1; then
  echo "Starting Felix's local model server..."
  "\$OLLAMA_BIN" serve >/tmp/felix-pull-serve-\$\$.log 2>&1 &
  SERVE_PID=\$!
  for _ in \$(seq 1 60); do
    sleep 0.5
    if curl -fsS "http://\$OLLAMA_HOST/api/version" >/dev/null 2>&1; then
      break
    fi
  done
  if ! curl -fsS "http://\$OLLAMA_HOST/api/version" >/dev/null 2>&1; then
    echo "ERROR: ollama server did not start. See /tmp/felix-pull-serve-\$\$.log"
    [ -n "\$SERVE_PID" ] && kill "\$SERVE_PID" 2>/dev/null
    exit 1
  fi
fi

"\$OLLAMA_BIN" pull "\$MODEL"
PULL_RC=\$?

if [ -n "\$SERVE_PID" ]; then
  kill "\$SERVE_PID" 2>/dev/null
  wait "\$SERVE_PID" 2>/dev/null
fi

echo
if [ "\$PULL_RC" -eq 0 ]; then
  echo "Done. \$MODEL is ready — Felix will use it on next launch."
else
  echo "Pull failed (exit \$PULL_RC). You can retry by re-running this script or by"
  echo "launching Felix and running: felix model pull \$MODEL"
fi
echo "(You can close this window.)"
HELPER_EOF
    chmod +x "$HELPER"
    chown "$LOGGED_IN_USER" "$HELPER"

    sudo -u "$LOGGED_IN_USER" osascript <<OSASCRIPT >/dev/null 2>&1 || true
tell application "Terminal"
  activate
  do script "bash $HELPER; rm -f $HELPER"
end tell
OSASCRIPT

    exit 0
  fi

  # Ask which provider
  PROVIDER=$(sudo -u "$LOGGED_IN_USER" osascript <<'OSASCRIPT'
set providers to {"OpenAI (GPT)"}
set chosen to choose from list providers ¬
  with prompt "Choose your default AI provider for Felix:" ¬
  default items {"OpenAI (GPT)"} ¬
  without multiple selections allowed and empty selection allowed
if chosen is false then return "skip"
return item 1 of chosen
OSASCRIPT
  )

  API_KEY=""
  BASE_URL=""
  MODEL=""
  PROVIDER_KEY=""

  case "$PROVIDER" in
    "Anthropic (Claude)")
      PROVIDER_KEY="anthropic"
      MODEL="anthropic/claude-sonnet-4-5"
      DEFAULT_URL="https://api.anthropic.com"
      ;;
    "OpenAI (GPT)")
      PROVIDER_KEY="openai"
      MODEL="openai/gpt-5.4"
      DEFAULT_URL="https://api.openai.com/v1"
      ;;
    "Google Gemini")
      PROVIDER_KEY="gemini"
      MODEL="gemini/gemini-2.0-flash"
      DEFAULT_URL="https://generativelanguage.googleapis.com"
      ;;
    "DeepSeek")
      PROVIDER_KEY="deepseek"
      MODEL="deepseek/deepseek-chat"
      DEFAULT_URL="https://api.deepseek.com"
      ;;
    "Ollama (local — no key needed)")
      PROVIDER_KEY="ollama"
      MODEL="ollama/llama3.2"
      DEFAULT_URL="http://localhost:11434"
      ;;
    *)
      PROVIDER_KEY=""
      MODEL=""
      DEFAULT_URL=""
      ;;
  esac

  if [ -n "$PROVIDER_KEY" ]; then

    # Ask for API key (skip for Ollama)
    if [ "$PROVIDER_KEY" != "ollama" ]; then
      API_KEY=$(sudo -u "$LOGGED_IN_USER" osascript <<OSASCRIPT
set r to display dialog "Enter your $PROVIDER API key:" default answer "" with title "Felix Setup" buttons {"Skip", "OK"} default button "OK" with hidden answer
if button returned of r is "Skip" then return ""
return text returned of r
OSASCRIPT
      ) || API_KEY=""
    fi

    # Ask for base URL (pre-filled with the provider default)
    BASE_URL=$(sudo -u "$LOGGED_IN_USER" osascript <<OSASCRIPT
set r to display dialog "Base URL for $PROVIDER:" default answer "$DEFAULT_URL" with title "Felix Setup" buttons {"Use Default", "OK"} default button "OK"
if button returned of r is "Use Default" then return "$DEFAULT_URL"
set entered to text returned of r
if entered is "" then return "$DEFAULT_URL"
return entered
OSASCRIPT
    ) || BASE_URL="$DEFAULT_URL"

    # Build provider JSON block
    if [ "$PROVIDER_KEY" = "ollama" ]; then
      PROVIDER_JSON="\"$PROVIDER_KEY\": { \"base_url\": \"$BASE_URL\" }"
    elif [ -n "$API_KEY" ] && [ -n "$BASE_URL" ]; then
      PROVIDER_JSON="\"$PROVIDER_KEY\": { \"api_key\": \"$API_KEY\", \"base_url\": \"$BASE_URL\" }"
    elif [ -n "$API_KEY" ]; then
      PROVIDER_JSON="\"$PROVIDER_KEY\": { \"api_key\": \"$API_KEY\" }"
    else
      PROVIDER_JSON="\"$PROVIDER_KEY\": { \"base_url\": \"$BASE_URL\" }"
    fi

  fi

  # Write felix.json5
  cat > "$CONFIG" << EOF
{
  "gateway": {
    "host": "127.0.0.1",
    "port": 18789,
    "auth": { "token": "" }
  },
  "providers": {
    $PROVIDER_JSON
  },
  "agents": {
    "list": [
      {
        "id": "default",
        "name": "Assistant",
        "workspace": "$FELIX_DIR/workspace-default",
        "model": "$MODEL",
        "sandbox": "none",
        "tools": {
          "allow": ["read_file","write_file","edit_file","bash",
                    "web_fetch","web_search","browser","send_message","cron"]
        }
      }
    ]
  },
  "bindings": [
    { "agentId": "default", "match": { "channel": "cli" } }
  ],
  "channels": {
    "cli": { "enabled": true, "interactive": true }
  },
  "heartbeat": { "interval": "30m", "enabled": false },
  "cortex": { "enabled": true, "llmModel": "gpt-5-mini" }
}
EOF

fi  # end config setup

# ---------------------------------------------------------------------------
# Fix ownership — everything should belong to the installing user
# ---------------------------------------------------------------------------
chown -R "$LOGGED_IN_USER" "$FELIX_DIR"

exit 0
